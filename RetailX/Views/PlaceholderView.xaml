<UserControl x:Class="RetailX.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="{Binding Description}"
                       Margin="0,4,0,0"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="30"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="14"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="180"
                        Height="180"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#EAF7F4"
                        BorderBrush="#BFE7D3"
                        BorderThickness="1"
                        CornerRadius="90">
                    <TextBlock Text="RX"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            MaxWidth="620">
                    <TextBlock Text="Module foundation ready"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="This workspace is prepared for the next implementation milestone with the same Retail-X design system, spacing, typography and navigation shell."
                               Margin="0,12,0,22"
                               FontSize="16"
                               LineHeight="24"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}" />
                    <UniformGrid Columns="3" Rows="1">
                        <Border Margin="0,0,10,0" Padding="14" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10">
                            <TextBlock Text="Clean forms" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Margin="5,0,5,0" Padding="14" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10">
                            <TextBlock Text="Fast tables" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Margin="10,0,0,0" Padding="14" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10">
                            <TextBlock Text="POS-ready UX" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
