<UserControl x:Class="RetailX.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RetailX.Controls">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Width="430"
                Padding="34"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Retail-X"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}" />
                <TextBlock Text="by CodaWix™"
                           Margin="0,2,0,28"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}" />

                <TextBlock Text="Username" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                <TextBox Margin="0,6,0,14"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Password" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                <PasswordBox Margin="0,6,0,8"
                             controls:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,4,0,12"
                           Foreground="{StaticResource DangerBrush}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource ZeroToVisibilityConverter}}" />

                <Button Content="Sign In"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}" />

                <Border Margin="0,24,0,0"
                        Padding="14"
                        Background="#F4F8FB"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Foreground="{StaticResource MutedBrush}"
                               Text="Development login: admin / admin123"
                               FontSize="13" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
