<UserControl x:Class="RetailX.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RetailX.Controls">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EAF5F4" Offset="0" />
                <GradientStop Color="#F7FAFC" Offset="0.55" />
                <GradientStop Color="#EAF1F7" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="880"
                MinHeight="500"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Direction="270"
                                  Opacity="0.14"
                                  Color="#1B2D3D" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="14,0,0,14"
                        Padding="30">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0B5364" Offset="0" />
                            <GradientStop Color="#087C8D" Offset="0.58" />
                            <GradientStop Color="#1F8A62" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Border Width="58"
                                    Height="58"
                                    Background="#22FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,18">
                                <TextBlock Text="RX"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="Retail-X"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="White" />
                            <TextBlock Text="by CodaWix™"
                                       Margin="0,4,0,0"
                                       FontSize="16"
                                       Foreground="#D8F3F1" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Supermarket checkout foundation"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Fast cashier workflow, stock-aware sales, and clean retail controls."
                                       Margin="0,12,0,0"
                                       FontSize="14"
                                       LineHeight="22"
                                       Foreground="#D8F3F1"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Text="© 2026 Adheesha Sooriyaarachchi. CodaWix™"
                                   FontSize="11"
                                   Foreground="#D8F3F1"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1"
                            Width="390"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Sign in"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="Open the cashier workspace"
                               Margin="0,4,0,28"
                               FontSize="14"
                               Foreground="{StaticResource MutedBrush}" />

                    <TextBlock Text="Username" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                    <TextBox Margin="0,7,0,16"
                             MinHeight="46"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Password" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                    <PasswordBox x:Name="PasswordInput"
                                 Margin="0,7,0,8"
                                 MinHeight="46"
                                 controls:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PasswordChanged="OnPasswordChanged"
                                 KeyDown="OnPasswordKeyDown" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               Margin="0,4,0,14"
                               Foreground="{StaticResource DangerBrush}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource ZeroToVisibilityConverter}}" />

                    <Button Content="Sign In"
                            MinHeight="48"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}" />

                    <Border Margin="0,24,0,0"
                            Padding="14"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock Foreground="{StaticResource MutedBrush}"
                                   Text="Development login: admin / admin123"
                                   FontSize="13" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
