<UserControl x:Class="RetailX.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Reports"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="Today’s supermarket performance at a glance."
                       Margin="0,3,0,0"
                       FontSize="14"
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="4" Rows="1" Margin="0,0,0,18">
            <Border Margin="0,0,12,0" Padding="20" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="TODAY SALES" FontSize="12" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding TodaySalesTotal, StringFormat=LKR {0:N2}}" FontSize="27" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,8,0,0" />
                    <TextBlock Text="Completed checkout total" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Margin="6,0,12,0" Padding="20" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="BILLS TODAY" FontSize="12" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding TodayBillCount}" FontSize="31" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0" />
                    <TextBlock Text="Invoices issued" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Margin="6,0,12,0" Padding="20" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="LOW STOCK" FontSize="12" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding LowStockCount}" FontSize="31" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,6,0,0" />
                    <TextBlock Text="Products need attention" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Margin="6,0,0,0" Padding="20" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="PAYMENTS" FontSize="12" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding PaymentSummary}" TextWrapping="Wrap" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,9,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Padding="22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Top selling products"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <Border Margin="0,18,0,0"
                            Height="190"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="Top product chart placeholder"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Cashier-wise sales"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <Border Margin="0,18,0,0"
                            Height="190"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="Cashier summary placeholder"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
