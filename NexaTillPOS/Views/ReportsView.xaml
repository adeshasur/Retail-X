<UserControl x:Class="NexaTillPOS.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Reports Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{StaticResource InkBrush}"
                   Margin="0,0,0,18" />

        <UniformGrid Grid.Row="1" Columns="2" Rows="2">
            <Border Margin="0,0,12,12" Padding="24" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Today Sales Total" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding TodaySalesTotal, StringFormat=LKR {0:N2}}" FontSize="34" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Margin="12,0,0,12" Padding="24" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Bills Today" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding TodayBillCount}" FontSize="34" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Margin="0,12,12,0" Padding="24" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Low Stock Products" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding LowStockCount}" FontSize="34" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Margin="12,12,0,0" Padding="24" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Payment Method Summary" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
                    <TextBlock Text="{Binding PaymentSummary}" TextWrapping="Wrap" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
