<UserControl x:Class="NexaTillPOS.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#14202C">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="18,20">
                    <TextBlock Text="NexaTill"
                               FontSize="27"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="POS by CodaWix"
                               Foreground="#B9C9D7"
                               FontSize="13" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="14">
                    <TextBlock Text="{Binding CashierName}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding UserRole}" Foreground="#B9C9D7" Margin="0,2,0,12" />
                    <Button Content="Logout" Command="{Binding LogoutCommand}" />
                </StackPanel>

                <StackPanel Margin="12,92,12,12">
                    <Button Content="Cashier POS" Command="{Binding NavigatePosCommand}" Margin="0,0,0,8" />
                    <Button Content="Products" Command="{Binding NavigateProductsCommand}" Margin="0,0,0,8" />
                    <Button Content="Inventory" Command="{Binding NavigateInventoryCommand}" Margin="0,0,0,8" />
                    <Button Content="Sales" Command="{Binding NavigateSalesCommand}" Margin="0,0,0,8" />
                    <Button Content="Reports" Command="{Binding NavigateReportsCommand}" Margin="0,0,0,8" />
                    <Button Content="Settings" Command="{Binding NavigateSettingsCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    Padding="22,0">
                <DockPanel VerticalAlignment="Center">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding AppName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="{Binding BranchName}" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding CurrentDateTime}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="{Binding CashierName, StringFormat=Cashier: {0}}" FontSize="12" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentModule}" />
        </Grid>
    </Grid>
</UserControl>
