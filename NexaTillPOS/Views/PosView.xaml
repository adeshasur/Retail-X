<UserControl x:Class="NexaTillPOS.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:NexaTillPOS.ViewModels"
             Loaded="OnLoaded">
    <UserControl.InputBindings>
        <KeyBinding Key="F1" Command="{Binding SearchCommand}" />
        <KeyBinding Key="F4" Command="{Binding HoldBillCommand}" />
        <KeyBinding Key="F5" Command="{Binding CompleteSaleCommand}" />
        <KeyBinding Key="F8" Command="{Binding SetCashCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelBillCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0"
                Grid.Row="0"
                Padding="14"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Margin="0,0,14,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         FontSize="22"
                         FontWeight="SemiBold"
                         MinHeight="54"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="OnSearchKeyDown" />
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Content="Search / Add"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SearchCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Column="0" Grid.Row="1" Margin="0,0,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding CartLines}"
                      SelectedItem="{Binding SelectedLine}"
                      FontSize="15">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="110" IsReadOnly="True" />
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                    <DataGridTextColumn Header="Discount" Binding="{Binding Discount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100" />
                    <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="120" IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Remove" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type viewModels:CartLineViewModel}">
                                <Button Content="X"
                                        MinHeight="30"
                                        Padding="8,2"
                                        Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding SearchResults.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                <ListBox ItemsSource="{Binding SearchResults}"
                         MaxHeight="150"
                         MouseDoubleClick="OnSearchResultDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="8">
                                <TextBlock Text="{Binding SellingPrice, StringFormat=LKR {0:N2}}"
                                           DockPanel.Dock="Right"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}" />
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{Binding SKU}" />
                                        <Run Text="  |  " />
                                        <Run Text="{Binding Barcode}" />
                                        <Run Text="  |  Stock " />
                                        <Run Text="{Binding StockQuantity}" />
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Grid.Row="0"
                Grid.RowSpan="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="GRAND TOTAL" Foreground="{StaticResource MutedBrush}" FontSize="13" FontWeight="Bold" />
                    <TextBlock Text="{Binding GrandTotal, StringFormat=LKR {0:N2}}"
                               FontSize="39"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,2,0,18" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="48" />
                        <RowDefinition Height="38" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Subtotal" Grid.Row="0" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding Subtotal, StringFormat=LKR {0:N2}}" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />
                    <TextBlock Text="Discount" Grid.Row="1" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding Discount, StringFormat=LKR {0:N2}}" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" />
                    <TextBlock Text="Tax/VAT" Grid.Row="2" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding Tax, StringFormat=LKR {0:N2}}" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" />
                    <TextBlock Text="Paid Amount" Grid.Row="3" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                    <TextBox Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Grid.Row="3" Grid.Column="1" Width="145" />
                    <TextBlock Text="Balance" Grid.Row="4" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="{Binding Balance, StringFormat=LKR {0:N2}}" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding SelectedPaymentMethod, StringFormat=Payment: {0}}" Grid.Row="5" Grid.ColumnSpan="2" Foreground="{StaticResource MutedBrush}" />
                </Grid>

                <StackPanel Grid.Row="2">
                    <UniformGrid Columns="2" Rows="2" Margin="0,0,0,12">
                        <Button Content="Cash  F8" Command="{Binding SetCashCommand}" Margin="0,0,6,6" />
                        <Button Content="Card" Command="{Binding SetCardCommand}" Margin="6,0,0,6" />
                        <Button Content="QR" Command="{Binding SetQrCommand}" Margin="0,6,6,0" />
                        <Button Content="Split Payment" Command="{Binding SetSplitCommand}" Margin="6,6,0,0" />
                    </UniformGrid>

                    <UniformGrid Columns="2" Rows="3">
                        <Button Content="Hold Bill F4" Command="{Binding HoldBillCommand}" Margin="0,0,6,6" />
                        <Button Content="Recall Bill" Command="{Binding RecallBillCommand}" Margin="6,0,0,6" />
                        <Button Content="Void Item" Command="{Binding VoidSelectedLineCommand}" Margin="0,6,6,6" />
                        <Button Content="Cancel Esc" Command="{Binding CancelBillCommand}" Style="{StaticResource DangerButton}" Margin="6,6,0,6" />
                        <Button Content="Complete F5" Command="{Binding CompleteSaleCommand}" Style="{StaticResource SuccessButton}" Margin="0,6,6,0" />
                        <Button Content="Print Receipt" Command="{Binding PrintReceiptCommand}" Margin="6,6,0,0" />
                    </UniformGrid>
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,18,0,0" />
            </Grid>
        </Border>

        <TextBlock Grid.Column="0"
                   Grid.Row="2"
                   Text="F1 Search Product   F2 Quantity   F3 Discount   F4 Hold Bill   F5 Complete Sale   F8 Cash Payment   Esc Cancel"
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,12,14,0" />
    </Grid>
</UserControl>
